# Required: OpenAI API key for LLM and embedding calls
OPENAI_API_KEY=your-api-key

# Optional: Override default model (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Optional: Override embedding model (default: text-embedding-3-small)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: Azure OpenAI (set all four to use Azure OpenAI instead of OpenAI directly)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=your-chat-deployment-name
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=your-embedding-deployment-name
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
